{
  "name": "@rs/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 9515",
    "dev:doc": "vitepress dev docs",
    "build:doc": "vitepress build docs",
    "start": "vite build && vite preview --port 9515",
    "build": "vite build",
    "build:cf": "NITRO_PRESET=cloudflare-pages vite build",
    "deploy": "NITRO_PRESET=cloudflare-pages vite build && wrangler pages deploy dist --project-name smpp-sms-web --commit-dirty=true",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier",
    "check": "prettier --write . && eslint --fix"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@fontsource-variable/inter": "^5.2.8",
    "@rs/sdk": "workspace:*",
    "@rs/ui": "workspace:*",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-devtools": "catalog:tanstack",
    "@tanstack/react-query": "catalog:tanstack",
    "@tanstack/react-router": "catalog:tanstack",
    "@tanstack/react-router-devtools": "catalog:tanstack",
    "@tanstack/react-router-ssr-query": "catalog:tanstack",
    "@tanstack/react-start": "catalog:tanstack",
    "@tanstack/router-plugin": "catalog:tanstack",
    "clsx": "catalog:",
    "lucide-react": "catalog:",
    "zod": "catalog:",
    "nitro": "latest",
    "radix-ui": "catalog:",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "shadcn": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "vitepress": "^1.6.3",
    "wrangler": "catalog:",
    "@tanstack/devtools-vite": "catalog:tanstack",
    "@tanstack/eslint-config": "catalog:tanstack",
    "@testing-library/dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-react": "catalog:",
    "jsdom": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "web-vitals": "catalog:"
  }
